<Window x:Class="FinanceTracker.Views.AddTransactionView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinanceTracker.Views"
         xmlns:sys="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="{Binding Title}" Height="420" Width="420"
        MinHeight="420" MinWidth="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="#F5F7FA">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolYoVisibilityConverter"/>
        <!-- Reusable label style -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="#2C3E50"/>
            <Setter Property="Margin"       Value="0,0,0,4"/>
        </Style>

        <!-- Reusable input style — TextBox and ComboBox share this -->
        <Style x:Key="InputControl" TargetType="Control">
            <Setter Property="Height"       Value="36"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="8,0"/>
            <Setter Property="BorderBrush"  Value="#D0D0D0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background"   Value="White"/>
        </Style>

        <!-- Reusable button style base -->
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height"          Value="38"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
        </Style>
    </Window.Resources>
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Style="{StaticResource FieldLabel}" Text="Type"/>
            <ComboBox Style="{StaticResource InputControl}" ItemsSource="{Binding TransactionTypes}" 
                      SelectedItem="{Binding Type, Mode=TwoWay}"/>

        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Style="{StaticResource FieldLabel}" Text="Amount"/>
            <TextBox Text="{Binding Amount, StringFormat={}{0:N2},
                UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="4">
            <TextBlock Style="{StaticResource FieldLabel}" Text="Category"/>
            <ComboBox Style="{StaticResource InputControl}" ItemsSource="{Binding Categories}" 
            SelectedItem="{Binding SelctedCategory, Mode=TwoWay}" DisplayMemberPath="{Binding Name}"/>
        </StackPanel>

        <StackPanel Grid.Row="6">
            <TextBlock Text="Date" Style="{StaticResource FieldLabel}"/>
            <DatePicker SelectedDate="{Binding Date, Mode=TwoWay}" 
                        DisplayDateEnd="{x:Static sys:DateTime.Today}"
                        Height="36" FontSize="13"
                        BorderBrush="#D0D0D0" BorderThickness="1"
                        Background="White"/>
        </StackPanel>

        <StackPanel Grid.Row="8">
            <TextBlock Text="Note (Optional)}" Style="{StaticResource FieldLabel}"/>
            <TextBox Text="{Binding Note, Mode=TwoWay,
                               UpdateSourceTrigger=PropertyChanged}"
                     Height="36"
                     FontSize="13"
                     Padding="8,0"
                     BorderBrush="#D0D0D0" BorderThickness="1"
                     Background="White"
                     VerticalContentAlignment="Center"
                     MaxLength="200"/>
        </StackPanel>
        <Border Grid.Row="10"
                Background="#FDECEA"
                BorderBrush="#E74C3C"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10,6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <!-- Show the error box only when there is a message -->
                        <DataTrigger Binding="{Binding ValidationMessage}"
                                     Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ValidationMessage}"
                                     Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠  " Foreground="#E74C3C" FontWeight="Bold"/>
                <TextBlock Text="{Binding ValidationMessage}"
                           Foreground="#C0392B"
                           FontSize="12"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
        <Grid Grid.Row="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Cancel -->
            <Button Grid.Column="0"
                    Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource DialogButton}"
                    Background="#ECF0F1"
                    Foreground="#2C3E50"/>

            <Button Grid.Column="2"
                    Content="{Binding SaveButtonLabel}"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource DialogButton}">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource DialogButton}">
                        <Setter Property="Background" Value="#3498DB"/>
                        <Setter Property="Foreground" Value="White"/>
                        <!-- Auto grey-out when SaveCommand.CanExecute = false -->
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#BDC3C7"/>
                                <Setter Property="Foreground" Value="#7F8C8D"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
</Window>
